LITELLM_API_KEY=your-api-key-here
LITELLM_API_BASE=https://your-endpoint-here
LITELLM_MODEL=openai/api-gpt-oss-120b

# Enrichment source credentials (all optional; sources skip gracefully)
OPENALEX_MAILTO=you@ucsd.edu        # joins the OpenAlex/Crossref polite pool
NCBI_API_KEY=                       # PubMed: 3 -> 10 req/s
S2_API_KEY=                         # Semantic Scholar quota
PATENTSVIEW_API_KEY=                # USPTO PatentsView (free registration)
ADS_API_KEY=                        # NASA ADS (free, 5k req/day)
REPEC_API_CODE=                     # RePEc/IDEAS (free registration)

# Scheduler tuning (optional)
EAH_RECONCILE_HOUR=6
BACKFILL_HOUR=2
BACKFILL_TIME_BUDGET=14400
